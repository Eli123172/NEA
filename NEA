import sqlite3
import hashlib

BG_COLOUR = "#57C3D9"#outer background
PANEL_COLOUR = "#6DADDB"#inner box
TEXT_COLOUR = "black"
FONT = ("Calibri", 12)#normal text
TITLE_FONT = ("Calibri", 18)#headings



def hash_password(password):
    #passwords are hashed using SHA-256 before being stored, improving its secutiry
    return hashlib.sha256(password.encode()).hexdigest()



def register():

    username = enter_username.get()
    password = enter_password.get()
    #takes what the user typed

    if len(password) < 8:
        messagebox.showerror("error", "Please enter a password that is at least 8 characters")
        #ensures that password entered is 8 characters long
        return

    hashed_password = hash_password(password)
    #makes the password secure via hashing

    db = sqlite3.connect("powerlifting.db")#opens the database
    cursor = db.cursor()#this is used to run SQL commands

    try:#makes sure code doesnt crash if error occurs
        cursor.execute(
            "INSERT INTO users (username, password) VALUES (?, ?)",
            (username, hashed_password)
        )
        db.commit()
        messagebox.showinfo("Success", "Your account has been created")
        
    except sqlite3.IntegrityError:
        messagebox.showerror("Error", "Username already exists")

    except Exception as e:
        messagebox.showerror("Error", str(e))

    db.close()#closes the database
    
    
    
def login():
    
    username = enter_username.get()#gets the username inputted into the box
    password = hash_password(enter_password.get())#gets the inputted password and hashes is so it matches the stored one
    
    db = sqlite3.connect("powerlifting.db")#opens database
    cursor = db.cursor()#creates a cursor to run the sql comands
    
    cursor.execute(#starts the command
        "SELECT * FROM users WHERE username=? AND password=?",#looks for a user where both password and usernae match
        (username, password)
    )#ends command
    
    result = cursor.fetchone()#gets thye first matching result, if there isnt any match then reurns none
    
    db.close()#closes database
    
    if result:#checks if matching user exists
        messagebox.showinfo("Login", "Login successful")#shows that it was successful
        window.withdraw()#hides the login window
        open_navigation()#opens the navigation page
    else:#runs if no match exists
        messagebox.showerror("Error", "Invalid username or password")#shows that it was unsuccessful



