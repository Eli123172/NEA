def open_program_selection():

    prog_win = tk.Toplevel()#prog_win=program window
    prog_win.title("Select Program")#creates title
    prog_win.geometry("400x300")#window size
    prog_win.configure(bg=BG_COLOUR)#background colour

    panel = tk.Frame(prog_win, bg=PANEL_COLOUR, padx=30, pady=20)#creates a panel
    panel.pack(pady=40)#displayes the panel

    tk.Label(panel, text="Select Program", bg=PANEL_COLOUR, font=TITLE_FONT).pack(pady=10)

    db = sqlite3.connect("powerlifting.db")#opens the database
    cursor = db.cursor()

    cursor.execute("SELECT id, name FROM programs")
    programs = cursor.fetchall()#stores all of the results in a list

    db.close()

    for prog_id, name in programs:
        tk.Button(
            panel,
            text=name,
            command=lambda p=prog_id: open_program(p)#locks the correct id per button
        ).pack(pady=5)
        
        
        
def open_program(program_id):#creates a function

    used = tk.Toplevel()#opens a new window to show the workout
    used.title("Workout program")#title of the window
    used.geometry("400x400")#window size
    used.configure(bg=BG_COLOUR)#colour of the background

    canvas = tk.Canvas(used, bg=BG_COLOUR)#creates a canvas widget, so we can scroll
    canvas.pack(side="left", fill="both", expand=True)#displays canvas on the left side

    scrollbar = tk.Scrollbar(used, command=canvas.yview)#creates a vertical scrollbar, and links it to canvas movement
    scrollbar.pack(side="right", fill="y")#displays the scrollbar on the right hand side and stretches it vertically

    canvas.configure(yscrollcommand=scrollbar.set)#enstres that the scrollbar updates when the user scrolls

    panel = tk.Frame(canvas, bg=PANEL_COLOUR)#creates a frame inside the canvas for all of the workout content
    canvas.create_window((0, 0), window=panel, anchor="nw")#places the panel inside the canvas

    def on_configure(event):#creates a function that runs every time that the panel changes size
        canvas.configure(scrollregion=canvas.bbox("all"))#ensures that scrolling includes everything

    panel.bind("<Configure>", on_configure)#triggers the function when the panel changes size

    db = sqlite3.connect("powerlifting.db")#opens the database
    cursor = db.cursor()

    cursor.execute(#gets exercises for the program
        "SELECT name, sets, reps, rpe FROM exercises WHERE program_id=?",
        (program_id,)#inserts id
    )
    exercises = cursor.fetchall()#fetches all matching exercises

    db.close()

    tk.Label(panel, text="Workout Program", bg=PANEL_COLOUR, font=TITLE_FONT).pack(pady=10)#page title

    entries = {}#creates a dictionary to store user inputs

    for name, sets, reps, rpe in exercises:#loops through exercises
        tk.Label(panel, text=name, bg=PANEL_COLOUR, font=FONT).pack()#displays exercise name
        tk.Label(panel, text=f"{sets} sets, {reps} reps, RPE {rpe}", bg=PANEL_COLOUR).pack()#shows user what to do

        entry = tk.Entry(panel)#input field
        entry.pack(pady=5)

        entries[name] = entry#links exercise to the input box
    
    tk.Button(panel, text="Save Workout",#creates a button to save the workout
          command=lambda: save_workout(entries)).pack(pady=10)
    
    
    
def save_workout(entries):#defines a finction to save all of the workout inputs

    username = enter_username.get()#links the workout to the user that completed the workout

    db = sqlite3.connect("powerlifting.db")#opens dataase
    cursor = db.cursor()

    for exercise, entry in entries.items():#loopsthrough all exercises
        result = entry.get()#gets what the user has typed

        cursor.execute(#inserts data into table and uses placeholders (?) to prevent SQL injection
            "INSERT INTO workout_logs (username, exercise, result) VALUES (?, ?, ?)",
            (username, exercise, result)#what it stores
        )

    db.commit()#saves changes to the database
    db.close()#closes database

    messagebox.showinfo("Saved", "Workout saved successfully")#confirmation message
 



