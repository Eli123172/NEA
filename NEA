import tkinter as tk
from tkinter import messagebox
import sqlite3
import hashlib

def hash_password(password):
    #passwords are hashed using SHA-256 before being stored, improving its secutiry
    return hashlib.sha256(password.encode()).hexdigest()




def register():

    username = enter_username.get()
    password = enter_password.get()
    #takes what the user typed

    if len(password) < 8:
        messagebox.showerror("error", "Please enter a password that is at least 8 characters")
        #ensures that password entered is 8 characters long
        return

    hashed_password = hash_password(password)
    #makes the password secure via hashing

    db = sqlite3.connect("powerlifting.db")#opens the database
    cursor = db.cursor()#this is used to run SQL commands

    try:#makes sure code doesnt crash if error occurs
        cursor.execute(
            "INSERT INTO users (username, password) VALUES (?, ?)",#adds a new user with placeholders for safety
            (username, hashed_password)#actual values inserted
        )

        db.commit()#saves the new user

        messagebox.showinfo("Success", "Your account has been created")#confirms to the user that their account was created

    except sqlite3.IntegrityError:#runs if there is an error in the try block of code
        messagebox.showerror("Error", "The username entered already exists")

    except Exception as e:
        messagebox.showerror("Error", str(e))

    db.close()#closes the database
    
    
    
def login():
    
    username = enter_username.get()#gets the username inputted into the box
    password = hash_password(enter_password.get())#gets the inputted password and hashes is so it matches the stored one
    
    db = sqlite3.connect("powerlifting.db")#opens database
    cursor = db.cursor()#creates a cursor to run the sql comands
    
    cursor.execute(#starts the command
        "SELECT * FROM users WHERE username=? AND password=?",#looks for a user where both password and usernae match
        (username, password)
    )#ends command
    
    result = cursor.fetchone()#gets thye first matching result, if there isnt any match then reurns none
    
    db.close()#closes database
    
    if result:#checks if matching user exists
        messagebox.showinfo("Login", "Login successful")#shows that it was successful
        window.withdraw()#hides the login window
        open_navigation()#opens the navigation page
    else:#runs if no match exists
        messagebox.showerror("Error", "Invalid username or password")#shows that it was unsuccessful



def open_navigation():
    
    nav = tk.Toplevel()#creates a new window
    
    nav.title("Navigation page")#sets the title of the window
    nav.geometry("400x300")#sets the proportions and size of window
    
    tk.Label(nav, text="Main Menu").pack(pady=10)#creates window title
    
    tk.Button(nav, text="View Used Programs").pack(pady=5)#creates a button for navigation
    tk.Button(nav, text="View Videos").pack(pady=5)#creates a button for navigation
    tk.Button(nav, text="View Provided Programs").pack(pady=5)#creates a button for navigation
    tk.Button(nav, text="Account Details").pack(pady=5)#creates a button for navigation
    tk.Button(nav, text="Help").pack(pady=5)#creates a button for navigation



db = sqlite3.connect("powerlifting.db")

#a cursor allows us to execute SQL commands
cursor = db.cursor()

#this SQL command creates a table called 'users'
#IF NOT EXISTS prevents the table from being created multiple times
cursor.execute("""
CREATE TABLE IF NOT EXISTS users (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    username TEXT UNIQUE,
    password TEXT
)
""")

db.commit()
db.close()




window = tk.Tk()
window.title("Powerlifting Tracker")
window.geometry("400x300")

tk.Label(window, text="Username").pack()
enter_username = tk.Entry(window)
enter_username.pack()

tk.Label(window, text="Password").pack()
enter_password = tk.Entry(window, show="*")
enter_password.pack()

tk.Button(window, text = "register", command = register).pack(pady=5)
tk.Button(window, text="Login", command=login).pack(pady=5)

window.mainloop()
