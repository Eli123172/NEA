def open_program_selection():

    prog_win = tk.Toplevel()#prog_win=program window
    prog_win.title("Select Program")#creates title
    prog_win.geometry("400x300")#window size
    prog_win.configure(bg=BG_COLOUR)#background colour

    panel = tk.Frame(prog_win, bg=PANEL_COLOUR, padx=30, pady=20)#creates a panel
    panel.pack(pady=40)#displayes the panel

    tk.Label(panel, text="Select Program", bg=PANEL_COLOUR, font=TITLE_FONT).pack(pady=10)

    db = sqlite3.connect("powerlifting.db")#opens the database
    cursor = db.cursor()

    cursor.execute("SELECT id, name FROM programs")
    programs = cursor.fetchall()#stores all of the results in a list

    db.close()

    for program in programs:#creates a button for every program in the database
        tk.Button(panel, text=program[1],
                  command=lambda id=program[0]: open_program(id)).pack(pady=5)
        
        
        
def open_program(program_id):

    used = tk.Toplevel()
    used.title("Workout program")
    used.geometry("400x400")
    used.configure(bg=BG_COLOUR)

    panel = tk.Frame(used, bg=PANEL_COLOUR, padx=30, pady=20)
    panel.pack(pady=40)

    db = sqlite3.connect("powerlifting.db")
    cursor = db.cursor()

    cursor.execute(
        "SELECT name, sets, reps, rpe FROM exercises WHERE program_id=?",
        (program_id,)
    )
    exercises = cursor.fetchall()

    db.close()

    tk.Label(panel, text="Workout Program", bg=PANEL_COLOUR, font=TITLE_FONT).pack(pady=10)

    entries = {}

    for name, sets, reps, rpe in exercises:
        tk.Label(panel, text=name, bg=PANEL_COLOUR, font=FONT).pack()
        tk.Label(panel, text=f"{sets} sets, {reps} reps, RPE {rpe}", bg=PANEL_COLOUR).pack()

        entry = tk.Entry(panel)
        entry.pack(pady=5)

        entries[name] = entry
 



