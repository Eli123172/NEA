enter_username.pack()

tk.Label(panel, text="Password", bg=PANEL_COLOUR).pack()
enter_password = tk.Entry(panel, show="*")
enter_password.pack()

tk.Button(panel, text="Register", command=register).pack(pady=8)
tk.Button(panel, text="Login", command=login).pack(pady=5)

window.mainloop()
